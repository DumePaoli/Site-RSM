# ── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://votre-domaine.com

# ── Secrets ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-jwt-secret-min-32-chars
ADMIN_PASSWORD=change-this-admin-password

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── PayPal ───────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live

# ── License server ────────────────────────────────────────────────────────────
LICENSE_SERVER_URL=https://rsm-license-server.fly.dev
LICENSE_ADMIN_SECRET=change-this-secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASSWORD=mot-de-passe-application
SMTP_FROM=noreply@rustservermanager.pro
SMTP_FROM_NAME=Rust Server Manager Pro

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Download ──────────────────────────────────────────────────────────────────
DOWNLOAD_URL=https://github.com/dumepaoli/rust-server-manger2/releases/latest
